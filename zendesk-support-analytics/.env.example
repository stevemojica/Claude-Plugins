# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Your Zendesk subdomain only — e.g. "acme" for acme.zendesk.com
ZENDESK_SUBDOMAIN=your-subdomain-here

# Zendesk OAuth token with tickets:read scope
# Generate at: Admin Center → Apps and integrations → APIs → Zendesk API → OAuth Clients
ZENDESK_OAUTH_TOKEN=your_oauth_token_here
